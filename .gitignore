# ============================================================
# lot-salt-suite — .gitignore
# ============================================================

# --- Código legado físico (400 MB — manter apenas local) ---
# legance/ contém LOT_Tese e LOT_APB_v5 — congelados, nunca publicar
legance/

# --- Resultados de simulação (pesados, reproduzíveis pelo caso YAML) ---
results/
*.vtu
*.pvd
*.h5
*.hdf5
*.xdmf

# --- Baselines (pesados — manter apenas localmente) ---
# Inputs completos (57MB cada) — não versionar
tests/baselines/*_input.json
# Output detalhado (29MB) — não versionar
tests/baselines/*_detailed_output.json
# Resultados VTU/CSV — não versionar
tests/baselines/*.csv
tests/baselines/*.vtu
# Manter: outputs de referência pequenos (<100KB) são versionados normalmente

# --- Build artifacts ---
build/
Build/
cmake-build-*/
*.o
*.obj
*.a
*.lib
*.so
*.dll
*.exe
*.out
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
install_manifest.txt

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
.venv/
venv/
env/
*.egg
*.egg-info/
dist/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
*.cover

# --- Credenciais e segredos ---
.env
.env.*
*.key
*.pem
*.p12
secrets.yaml
secrets.json
.claude/settings.local.json

# --- IDEs ---
.vscode/settings.json
.vscode/*.code-workspace
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# --- Logs ---
*.log
logs/

# --- Documentação gerada (exceto index.html que é commitado) ---
docs/_build/
docs/__pycache__/

# --- Temporários ---
*.tmp
*.bak
*.orig
tmp/
temp/
