{
  "permissions": {
    "allow": [
      "Bash(cmake:*)",
      "Bash(ctest:*)",
      "Bash(pytest:*)",
      "Bash(python tools/*:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(./build/lot-sim:*)",
      "Bash(./build/Debug/lot-sim.exe:*)",
      "Bash(./build/Release/lot-sim.exe:*)",
      "Bash(./build/RelWithDebInfo/lot-sim.exe:*)",
      "Read(./**)",
      "Edit(apps/**)",
      "Edit(src/**)",
      "Edit(include/**)",
      "Edit(postprocess/**)",
      "Edit(tests/**)",
      "Edit(cases/**)",
      "Edit(schemas/**)",
      "Edit(docs/**)",
      "Edit(tools/**)",
      "Edit(CMakeLists.txt)",
      "Edit(pyproject.toml)",
      "Edit(CLAUDE.md)",
      "Edit(AGENTS.md)",
      "Edit(README.md)",
      "Edit(.gitignore)",
      "Edit(.claude/settings.json)",
      "Edit(.agents/**)",
      "Edit(external/saltcreep/CMakeLists.txt)",
      "Write(external/saltcreep/tests/test_eigen_source.cpp)"
    ],
    "deny": [
      "Edit(legance/**)",
      "Edit(external/saltcreep/src/**)",
      "Edit(external/saltcreep/include/**)",
      "Edit(external/saltcreep/cases/**)",
      "Edit(external/saltcreep/main/**)",
      "Edit(legacy/LOT_Tese/**)",
      "Edit(legacy/LOT_APB_v5/**)",
      "Bash(rm -rf:*)",
      "Bash(git reset --hard:*)",
      "Bash(git push --force:*)"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python tools/update_devlog.py",
            "if": "Bash(git commit:*)",
            "timeout": 30,
            "statusMessage": "Atualizando dev-log...",
            "async": true
          },
          {
            "type": "command",
            "command": "python tools/update_devlog.py",
            "if": "Bash(git push:*)",
            "timeout": 30,
            "statusMessage": "Atualizando dev-log após push...",
            "async": true
          }
        ]
      }
    ]
  }
}
